{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "declaration": false,
        "declarationMap": false,
        "jsx": "react-jsx",
        "lib": ["ES2023", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "types": ["node", "vite/client"],
        "baseUrl": ".",
        "paths": {
            "@/*": ["./sources/*"]
        }
    },
    "include": ["sources/**/*.ts", "sources/**/*.tsx", "vite.config.ts"]
}
